# ============================================
# AdminG - Variables de entorno requeridas
# Copiar como .env y rellenar valores reales
# ============================================

# OBLIGATORIO: Clave secreta para JWT. Genera una con:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia_esto_por_una_clave_secreta_muy_larga

# URL de la base de datos.
# SQLite (simple, datos se pierden si el contenedor se recrea):
DATABASE_URL=sqlite:///./app.db
# PostgreSQL (persistente, recomendado para producción):
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Puerto del servidor (Railway lo inyecta automáticamente)
PORT=8000
