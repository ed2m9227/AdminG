# ============================================
# AdminG - Variables de entorno requeridas
# Copiar como .env y rellenar valores reales
# ============================================

# OBLIGATORIO: Clave secreta para JWT. Genera una con:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia_esto_por_una_clave_secreta_muy_larga

# URL de la base de datos.
# SQLite (simple, datos se pierden si el contenedor se recrea):
DATABASE_URL=sqlite:///./app.db
# PostgreSQL (persistente, recomendado para producción):
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Puerto del servidor (Railway lo inyecta automáticamente)
PORT=8000

# Entorno
APP_ENV=development

# CORS
CORS_ALLOW_ALL_ORIGINS=false
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:8000,http://localhost:8000
FRONTEND_BASE_URL=http://127.0.0.1:8000

# Seguridad auth
AUTH_EXPOSE_RESET_TOKEN=true
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# SMTP (opcional en desarrollo, obligatorio en producción)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true
