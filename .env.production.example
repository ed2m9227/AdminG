# ============================================
# AdminG - Produccion segura
# Copiar a tu gestor de secretos / variables del hosting
# NO subir valores reales al repositorio
# ============================================

APP_ENV=production
SECRET_KEY=genera_una_clave_secreta_real_en_tu_hosting
DATABASE_URL=postgresql://usuario:password@host:5432/database

# CORS
CORS_ALLOW_ALL_ORIGINS=false
# Usa una lista separada por comas con TODOS los origenes publicos permitidos.
# Ejemplo: dominio Railway + dominio propio + www si aplica.
CORS_ALLOW_ORIGINS=https://adming-systems.up.railway.app,https://adming-systems.com,https://www.adming-systems.com
# Debe apuntar al frontend publico principal que recibira enlaces absolutos.
FRONTEND_BASE_URL=https://adming-systems.up.railway.app

# Auth
AUTH_EXPOSE_RESET_TOKEN=false
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# SMTP para recovery/reset
SMTP_HOST=smtp.tu-proveedor.com
SMTP_PORT=587
SMTP_USERNAME=usuario_smtp
SMTP_PASSWORD=clave_smtp
SMTP_FROM_EMAIL=no-reply@tu-dominio.com
SMTP_USE_TLS=true
FIELD_ENCRYPTION_KEY=clave_independiente_para_cifrado_de_campos
FIELD_ENCRYPTION_KEY_VERSION=v1

# Opcional
PORT=8000
