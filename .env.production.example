APP_ENV=production
SECRET_KEY=a7f9b3c2d1e8f4a5b6c7d8e9f0a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8
DATABASE_URL=sqlite:///./app.db

# CORS
CORS_ALLOW_ALL_ORIGINS=false
CORS_ALLOW_ORIGINS=https://127.0.0.1:8000
FRONTEND_BASE_URL=https://127.0.0.1:8000

# Auth
AUTH_EXPOSE_RESET_TOKEN=false
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# SMTP para recovery/reset
SMTP_HOST=smtp.tu-proveedor.com
SMTP_PORT=587
SMTP_USERNAME=usuario_smtp
SMTP_PASSWORD=clave_smtp
SMTP_FROM_EMAIL=no-reply@tu-dominio.com
SMTP_USE_TLS=true

# Opcional
PORT=8000
