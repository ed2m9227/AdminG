# ============================================
# AdminG - Produccion segura
# Copiar a tu gestor de secretos / variables del hosting
# NO subir valores reales al repositorio
# ============================================

APP_ENV=production
SECRET_KEY=REEMPLAZAR_CON_HEX_LARGO_GENERADO
DATABASE_URL=postgresql://user:password@host:5432/adming_prod

# CORS
CORS_ALLOW_ALL_ORIGINS=false
CORS_ALLOW_ORIGINS=https://tu-dominio.com,https://www.tu-dominio.com
FRONTEND_BASE_URL=https://tu-dominio.com

# Auth
AUTH_EXPOSE_RESET_TOKEN=false

# SMTP para recovery/reset
SMTP_HOST=smtp.tu-proveedor.com
SMTP_PORT=587
SMTP_USERNAME=usuario_smtp
SMTP_PASSWORD=clave_smtp
SMTP_FROM_EMAIL=no-reply@tu-dominio.com
SMTP_USE_TLS=true

# Opcional
PORT=8000
